echo "deb [arch=amd64] http://download.proxmox.com/debian/pve bookworm pve-no-subscription" > /etc/apt/sources.list.d/pve-install-repo.list
wget https://enterprise.proxmox.com/debian/proxmox-release-bookworm.gpg -O /etc/apt/trusted.gpg.d/proxmox-release-bookworm.gpg
apt update -q
apt install proxmox-auto-install-assistant -yq
curl -fSL https://enterprise.proxmox.com/iso/proxmox-ve_9.0-1.iso > proxmox.iso.upstream
proxmox-auto-install-assistant prepare-iso proxmox.iso.upstream --output proxmox.iso \
  --fetch-from iso --answer-file answers.toml

osirrox -dev proxmox.iso -extract /boot/grub/grub.cfg grub.cfg
sed -i "s/proxmox-start-auto-installer/proxmox-start-auto-installer net.ifnames=0/" grub.cfg
xorriso -dev proxmox.iso -update grub.cfg /boot/grub/grub.cfg -boot_image any keep


